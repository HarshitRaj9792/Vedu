vedulive.net2coder.in {

    # ── 1. LiveKit Signal WebSocket (/rtc*) ───────────────────────────────
    # handle blocks are mutually exclusive and ordered — first match wins
    handle /rtc* {
        reverse_proxy livekit:7880
    }

    # ── 2. LiveKit HTTP API (/twirp*) ─────────────────────────────────────
    handle /twirp* {
        reverse_proxy livekit:7880
    }

    # ── 3. MinIO recordings (students download over HTTPS) ────────────────
    # Strips /storage prefix before forwarding: /storage/recordings/x.mp4 → /recordings/x.mp4
    handle /storage/* {
        uri strip_prefix /storage
        reverse_proxy minio:9000
    }

    # ── 4. Everything else → Spring Boot backend ──────────────────────────
    handle {
        reverse_proxy vedu-backend:8080
    }
}

# HTTP → HTTPS redirect
http://vedulive.net2coder.in {
    redir https://{host}{uri} permanent
}
